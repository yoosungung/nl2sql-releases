# metadata repo 로컬용: cp .env.sample .env 후 값 채우기 (.env는 gitignore)
#
# pg-inspect · MODEL_AUTHORING: repo 루트 .env 의 MCP_POSTGRES_URL
# validate: backend 가 METADATA_REPO_PATH 로 이 repo 를 열고 있어야 함

# --- PostgreSQL (metadata-pg-introspect) ---
# local_postgres.source.json 의 name 과 일치 (기본 local_postgres)
MCP_POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
MCP_POSTGRES_SOURCE_NAME=local_postgres

# --- backend validate (metadata-validate) ---
# nl2sql README Quickstart: backend METADATA_REPO_PATH = 이 repo 절대경로
NL2SQL_BACKEND_URL=http://127.0.0.1:8080
VALIDATE_USER=validator
VALIDATE_EMAIL=validator@local

# validate-metadata.sh 가 monorepo .env 를 읽을 때 (선택)
# NL2SQL_ENV=/path/to/nl2sql/.env

# 이 clone 경로가 backend/MCP 와 다를 때만 (선택)
# METADATA_REPO_ROOT=/absolute/path/to/this-metadata-repo
